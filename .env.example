# ===================================================
# Paper Collection Agent - 환경 설정
# ===================================================
# 이 파일을 복사하여 .env 파일을 생성하세요:
#   copy .env.example .env
# 그리고 아래 값을 채워 넣으세요.

# ─── Gemini API Key ────────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# ─── 스케줄 시간 (24시간 형식) ─────────────────────
SCHEDULE_TIME=10:00

# ─── 검색 키워드 (쉼표 구분) ──────────────────────
KEYWORDS=On-device AI, ADL, Dementia Care, Edge AI, sLLM

# ─── 활성 수집 소스 (쉼표 구분) ───────────────────
# 사용 가능: arxiv, huggingface, semantic_scholar,
#           pubmed, openalex, biorxiv, medrxiv
ENABLED_SOURCES=arxiv,huggingface,semantic_scholar,pubmed,openalex,biorxiv,medrxiv

# ─── 소스별 최대 수집 개수 ────────────────────────
ARXIV_MAX_RESULTS=5
HF_MAX_RESULTS=5
SEMANTIC_SCHOLAR_MAX_RESULTS=5
PUBMED_MAX_RESULTS=5
OPENALEX_MAX_RESULTS=5
BIORXIV_MAX_RESULTS=1
MEDRXIV_MAX_RESULTS=1

# ─── 로그 레벨 ────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
